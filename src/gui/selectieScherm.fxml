<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<fx:root fx:id="root" minHeight="200.0" minWidth="600.0" prefHeight="200.0" prefWidth="600.0" styleClass="menuOption" type="BorderPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <left>
      <TableView fx:id="table_gebruikers" minWidth="200.0" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER_RIGHT">
        <columns>
          <TableColumn fx:id="tableColumn_gebruikersnaam" prefWidth="113.5999755859375" text="Gebruikersnaam" />
          <TableColumn fx:id="tableColumn_geboortejaar" prefWidth="85.5999755859375" text="Geboortejaar" />
        </columns>
      </TableView>
   </left>
   <center>
      <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Button fx:id="btn_voegToe" disable="true" mnemonicParsing="false" onAction="#voegSpelerToe" text="Voeg Toe" />
                  <Button fx:id="btn_verwijder" disable="true" mnemonicParsing="false" onAction="#verwijderSpeler" text="Verwijder" />
                  <Button fx:id="btn_annuleer" disable="true" mnemonicParsing="false" text="Annuleer" />
                  <HBox alignment="TOP_CENTER" spacing="20.0">
                     <children>
                        <Button fx:id="btn_terugNaarMenu" mnemonicParsing="false" onAction="#terugNaarMenu" text="Terug" />
                        <Button fx:id="btn_startSpel" disable="true" mnemonicParsing="false" onAction="#startSpel" text="Start">
                           <font>
                              <Font name="Times New Roman" size="12.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </VBox>
            <GridPane fx:id="grid_geselecteerdeSpelers" alignment="CENTER" hgap="5.0" prefWidth="200.0" vgap="5.0" HBox.hgrow="ALWAYS">
              <columnConstraints>
                <ColumnConstraints fx:id="grid_imageColumn_1" hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints fx:id="grid_imageColumn_2" hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints fx:id="grid_imageRow_1" minHeight="10.0" prefHeight="30.0" vgrow="ALWAYS" />
                <RowConstraints fx:id="grid_imageRow_2" minHeight="10.0" prefHeight="30.0" vgrow="ALWAYS" />
              </rowConstraints>
               <children>
                  <StackPane fx:id="sp_blauw" alignment="BOTTOM_CENTER" disable="true" styleClass="stackpane" GridPane.halignment="RIGHT" GridPane.valignment="BOTTOM">
                     <children>
                        <Pane fx:id="imagePane_spelerBlauw" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0" />
                        <Button fx:id="btn_blauw" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#selecteerBlauw" text="Speler">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font></Button>
                     </children>
                  </StackPane>
                  <StackPane fx:id="sp_geel" alignment="BOTTOM_CENTER" disable="true" styleClass="stackpane" GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.valignment="BOTTOM">
                     <children>
                        <Pane fx:id="imagePane_spelerGeel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0" />
                        <Button fx:id="btn_geel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#selecteerGeel" text="Speler">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font></Button>
                     </children>
                  </StackPane>
                  <StackPane fx:id="sp_groen" alignment="TOP_CENTER" disable="true" styleClass="stackpane" GridPane.halignment="RIGHT" GridPane.rowIndex="1" GridPane.valignment="TOP">
                     <children>
                        <Pane fx:id="imagePane_spelerGroen" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0" />
                        <Button fx:id="btn_groen" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#selecteerGroen" text="Speler">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font></Button>
                     </children>
                  </StackPane>
                  <StackPane fx:id="sp_rood" alignment="TOP_CENTER" disable="true" styleClass="stackpane" GridPane.columnIndex="1" GridPane.halignment="LEFT" GridPane.rowIndex="1" GridPane.valignment="TOP">
                     <children>
                        <Pane fx:id="imagePane_spelerRoos" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0" />
                        <Button fx:id="btn_rood" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#selecteerRood" text="Speler">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font></Button>
                     </children>
                  </StackPane>
               </children>
            </GridPane>
         </children>
      </HBox>
   </center>
   <stylesheets>
      <URL value="@css/main.css" />
      <URL value="@css/selectieScherm.css" />
   </stylesheets>
</fx:root>
